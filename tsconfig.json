{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ESNext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@keyhive/keyhive/slim": ["node_modules/@keyhive/keyhive/pkg-slim/index.d.ts"],
      "@keyhive/keyhive/keyhive_wasm.base64.js": ["node_modules/@keyhive/keyhive/pkg-slim/keyhive_wasm_bg.wasm.base64"],
      "@automerge/automerge-repo/slim": ["node_modules/@automerge/automerge-repo/dist/entrypoints/slim"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/client", "src/shared", "src/lib"]
}
