{
  "name": "automerge-docs",
  "version": "1.0.0",
  "description": "Applications using Automerge",
  "main": "index.js",
  "scripts": {
    "start": "ts-node src/backend/server.ts",
    "dev": "nodemon --watch src/backend --ext ts --exec ts-node src/backend/server.ts",
    "build": "vite build",
    "serve:prod": "NODE_ENV=production PORT=4000 ts-node src/backend/server.ts",
    "test": "jest && npm run test:cy",
    "test:cy": "npm run build && rm -rf .data-cypress && PORT=4444 NODE_ENV=production AUTOMERGE_DATA_DIR=.data-cypress start-server-and-test 'ts-node src/backend/server.ts' http://localhost:4444/health cy:run",
    "test:cy:open": "npm run build && rm -rf .data-cypress && PORT=4444 NODE_ENV=production AUTOMERGE_DATA_DIR=.data-cypress start-server-and-test 'ts-node src/backend/server.ts' http://localhost:4444/health cy:open",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "coverage:merge": "mkdir -p coverage/combined && nyc merge coverage coverage/combined/coverage-final.json && nyc report --temp-dir coverage/combined --report-dir coverage/combined --reporter text-summary --reporter lcov",
    "coverage": "npm run test:coverage && npm run test:cy && npm run coverage:merge",
    "cy:open": "./run-cypress.sh open",
    "cy:run": "./run-cypress.sh run",
    "stop": "pkill -f 'ts-node.*server.ts' || true",
    "syncthing": "node syncthing-automerge/merge.js ./.data"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@automerge/automerge": "^3.2.4",
    "@automerge/automerge-repo": "^2.5.3",
    "@automerge/automerge-repo-network-messagechannel": "^2.5.3",
    "@automerge/automerge-repo-network-websocket": "^2.5.3",
    "@automerge/automerge-repo-storage-indexeddb": "^2.5.3",
    "@automerge/automerge-repo-storage-nodefs": "^2.5.3",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@glideapps/glide-data-grid": "^6.0.3",
    "@preact/signals": "^2.8.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@schedule-x/calendar": "^4.1.0",
    "@schedule-x/current-time": "^4.1.0",
    "@schedule-x/events-service": "^4.1.0",
    "@schedule-x/theme-default": "^4.1.0",
    "@tailwindcss/vite": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "express": "^5.2.1",
    "hyperformula": "^3.2.0",
    "ical.js": "^2.1.0",
    "lucide-react": "^0.575.0",
    "multer": "^2.0.2",
    "preact": "^10.28.4",
    "preact-router": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "temporal-polyfill": "^0.3.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^4.0.1",
    "@lhci/cli": "^0.15.1",
    "@preact/preset-vite": "^2.10.3",
    "@testing-library/preact": "^3.2.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "cypress": "^15.10.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "nodemon": "^3.1.11",
    "nyc": "^18.0.0",
    "start-server-and-test": "^2.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-istanbul": "^7.2.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
