{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$tsc"
      ],
      "label": "npm: build",
      "detail": "tsc"
    },
    {
      "type": "npm",
      "script": "test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "label": "npm: test",
      "detail": "jest"
    },
    {
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
          "file": 1,
          "location": 2,
          "severity": 3,
          "code": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting `ts-node",
          "endsPattern": "Automerge Docs API server running"
        }
      },
      "label": "npm: dev",
      "detail": "nodemon --watch src --ext ts --exec ts-node src/server.ts"
    },
    {
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "test:watch"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "label": "npm: test:watch",
      "detail": "Run tests in watch mode"
    }
  ]
}
